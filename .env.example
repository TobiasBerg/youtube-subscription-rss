# Comes from the Google Cloud Console when you create an OAuth 2.0 Client ID for a Web Application.
YT_RSS_YOUTUBE_CLIENT_ID=
YT_RSS_YOUTUBE_CLIENT_SECRET=

# Generated by the refresh command
YT_RSS_YOUTUBE_REFRESH_TOKEN=

# Port to run the server on
YT_RSS_PORT=8080

# Public base URL of this server (e.g. https://rss.example.com).
# When set, the Atom feed will include absolute URLs for the feed icon and logo.
# If left empty, icon/logo elements are omitted from the feed.
YT_RSS_BASE_URL=

# Include Shorts if you want (this is false by default)
YT_RSS_INCLUDE_SHORTS=false
